{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RisenLab",
  "version": "0.1.18",
  "identifier": "com.risenlab.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RisenLab",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 700,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
